            android:theme="@android:style/Theme.NoTitleBar"></activity>
        <activity
            android:name=".BaiduSDKDemo"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

