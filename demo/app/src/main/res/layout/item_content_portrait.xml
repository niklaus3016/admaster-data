<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:src="@drawable/portrait_mountain"
        android:contentDescription="内容图片"
        android:scaleType="centerCrop"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/right_side"
        android:orientation="vertical"
        android:layout_width="42dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:layout_marginRight="16dp"
        android:layout_marginBottom="16dp" >

        <ImageView
            android:src="@drawable/ic_blue_paw"
            android:layout_marginBottom="24dp"
            android:layout_width="42dp"
            android:layout_height="42dp"/>

        <ImageView
            android:src="@drawable/ic_draw_right_side"
            android:layout_marginLeft="3dp"
            android:layout_width="36dp"
            android:layout_height="192dp"/>

    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_toLeftOf="@id/right_side"
        android:layout_alignParentBottom="true"
        android:layout_margin="16dp" >

        <TextView
            android:id="@+id/author"
            android:text="展示内容作者"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_marginBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_below="@id/author"
            android:text="此处展示内容的标题或描述之类的信息"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

    </RelativeLayout>

</RelativeLayout>