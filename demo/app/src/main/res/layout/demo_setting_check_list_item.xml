<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_height="wrap_content">
    <LinearLayout
        android:id="@+id/ll_setting_choose_parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:padding="15dp"
            android:layout_weight="2"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView
                android:id="@+id/tv_setting_choose_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#000"
                android:textSize="17dp"/>
            <TextView
                android:id="@+id/tv_setting_choose_des"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="13dp"
                android:visibility="gone"
                android:textColor="#888585"
                android:text=""/>
        </LinearLayout>
        <LinearLayout
            android:layout_weight="1"
            android:gravity="right"
            android:layout_width="0dp"
            android:layout_height="match_parent">
            <TextView
                android:layout_gravity="center"
                android:id="@+id/tv_setting_check_title"
                android:textSize="13dp"
                android:layout_marginRight="20dp"
                android:textColor="#888585"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""/>
        </LinearLayout>
    </LinearLayout>
    <View
        android:id="@+id/view_setting_choose_divider"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_width="match_parent"
        android:visibility="gone"
        android:background="#EFEFF4"
        android:layout_height="1dp"/>
</LinearLayout>