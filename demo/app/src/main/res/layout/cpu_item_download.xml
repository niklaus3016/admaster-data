<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/download_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="6dp"
    android:visibility="visible">

    <TextView
        android:id="@+id/app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/black"
        android:text="一键清理" />

    <TextView
        android:id="@+id/app_ver"
        android:layout_toRightOf="@id/app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:textColor="@color/gray"
        android:textSize="15sp"
        android:text="版本:8.008" />

    <TextView
        android:id="@+id/privacy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:layout_toRightOf="@id/app_ver"
        android:text="隐私"
        android:textColor="@color/gray"
        android:textSize="15sp"
        android:visibility="visible" />

    <TextView
        android:id="@+id/permission"
        android:visibility="visible"
        android:layout_toRightOf="@id/privacy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gray"
        android:textSize="15sp"
        android:layout_marginLeft="8dp"
        android:text="权限" />

    <TextView
        android:id="@+id/publisher"
        android:layout_below="@id/app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/gray"
        android:textSize="15sp"
        android:text="北京XXXX公司" />

    <com.baidu.mobads.demo.main.tools.CustomProgressButton
        android:id="@+id/download"
        android:layout_width="60dp"
        android:layout_height="27dp"
        android:layout_centerInParent="true"
        android:layout_toLeftOf="@id/bottom_container_mislike2"
        android:padding="3dp" />

    <TextView
        android:id="@+id/bottom_container_mislike2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_alignParentEnd="true"
        android:layout_marginLeft="6dp"
        android:text="X"
        android:textColor="@color/gray"
        android:background="@drawable/text_ring"/>

    <ImageView
        android:layout_width="13dp"
        android:layout_height="13dp"
        android:layout_marginTop="5dp"
        android:src="@drawable/new_bg_logo"
       android:layout_toLeftOf="@id/mob_adIcon_2x"
        android:scaleType="centerCrop"
        android:layout_below="@id/publisher"/>

    <ImageView
        android:id="@+id/mob_adIcon_2x"
        android:layout_width="25dp"
        android:layout_height="13dp"
        android:layout_marginTop="5dp"
        android:layout_alignParentEnd="true"
        android:layout_below="@id/publisher"
        android:src="@drawable/mob_adicon_2x"/>
</RelativeLayout>